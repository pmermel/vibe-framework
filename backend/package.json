{
  "name": "vibe-backend",
  "version": "0.1.0",
  "description": "Minimal backend for vibe-framework: bootstrap, preview support, screenshots, and status callbacks",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "postbuild": "mkdir -p dist/infrastructure && cp ../infrastructure/container-apps-env.json dist/infrastructure/container-apps-env.json",
    "predev": "mkdir -p src/infrastructure && cp ../infrastructure/container-apps-env.json src/infrastructure/container-apps-env.json",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "lint": "echo 'lint not configured yet' && exit 0",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@azure/arm-resources": "^5.0.0",
    "@azure/identity": "^4.13.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@octokit/auth-app": "^8.2.0",
    "@octokit/rest": "^22.0.1",
    "express": "^4.18.2",
    "libsodium-wrappers": "^0.8.2",
    "playwright": "^1.40.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/libsodium-wrappers": "^0.7.14",
    "@types/node": "^20.11.0",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  }
}
